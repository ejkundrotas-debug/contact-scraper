# =====================================================================
# Lead AI Contact Scraper v1.3 — Environment Variables
# =====================================================================
# Скопируйте этот файл в .env (cp .env.example .env) и заполните ключи.
# Минимально достаточно одного ключа из секции "AI providers".

# ─── AI providers ─────────────────────────────────────────────────────
# Один любой ключ — этого хватит для старта.
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=http://localhost:8501
OPENROUTER_SITE_NAME=Lead AI Scraper
GEMINI_API_KEY=

# Премиум-провайдеры (по желанию)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
XAI_API_KEY=

# ─── Russian AI providers ─────────────────────────────────────────────
# GigaChat: рекомендован GIGACHAT_AUTH_KEY для auto-refresh.
# AUTH_KEY = base64(client_id:client_secret) из личного кабинета Sber.
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Если auto-refresh не работает (нет сертификата) — можно получить токен вручную:
#   python scripts/gigachat_auth.py
# и положить сюда:
GIGACHAT_ACCESS_TOKEN=
# Отключить TLS-проверку для GigaChat (для dev, не для prod!):
GIGACHAT_INSECURE=0

# YandexGPT: требуется API-ключ + folder_id.
YANDEXGPT_API_KEY=
YANDEX_FOLDER_ID=

# ─── Search APIs (опционально, для discovery без seed-страниц) ────────
BRAVE_SEARCH_API_KEY=
SERPER_API_KEY=
TAVILY_API_KEY=

# ─── DaData (опционально, обогащение реквизитов) ──────────────────────
# Регистрация: https://dadata.ru/ (10 000 запросов/день бесплатно)
DADATA_API_KEY=

# ─── Google Sheets export (опционально) ───────────────────────────────
# Вариант 1: путь к JSON-файлу service-account или сам JSON.
GOOGLE_SERVICE_ACCOUNT_JSON=
# Вариант 2: простой webhook Apps Script (если не хотите ставить gspread).
GSHEETS_WEBHOOK_URL=
GSHEETS_WEBHOOK_TOKEN=

# ─── CRM integrations (опционально) ───────────────────────────────────
# Generic webhook (n8n, Make, Zapier, ваш fulfillment-эндпоинт)
CRM_WEBHOOK_URL=
CRM_WEBHOOK_TOKEN=

# Bitrix24 incoming webhook
BITRIX24_WEBHOOK_URL=

# amoCRM (long-lived token)
AMOCRM_SUBDOMAIN=
AMOCRM_ACCESS_TOKEN=

# HubSpot
HUBSPOT_ACCESS_TOKEN=

# ─── App settings ─────────────────────────────────────────────────────
SCRAPER_CONFIG=configs/config_default.yaml
SCRAPER_DB=data/leads.sqlite3
# 1 = разрешить скрапить localhost/private IP (только для локального dev!)
SCRAPER_ALLOW_PRIVATE_IPS=0

# Shop-logistics / Fulfillment CRM (специализированный плоский payload
# с логистическим профилем: маркетплейсы, объёмы, категории товаров)
SHOP_LOGISTICS_WEBHOOK_URL=
SHOP_LOGISTICS_TOKEN=
